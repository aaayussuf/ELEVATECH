# Copy to backend/.env and adjust if needed

# When running Flask from host machine, keep this as localhost.
# When running Flask inside the Docker container, set DATABASE_HOST=db.
# If you use this default, it will work with docker-compose.

DATABASE_URL=postgresql+psycopg2://bxtech:bxtech@db:5432/bxtech

FLASK_SECRET_KEY=change-me
CORS_ORIGINS=http://localhost:5173

# Seed demo data on startup (recommended for local dev)
SEED_DB_ON_STARTUP=true

